{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": ["**/*.json", "**/*.ts", "**/*.md"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "useBlockStatements": "error",
        "noNestedTernary": "error",
        "noParameterAssign": "error",
        "useExplicitLengthCheck": "error"
      },
      "complexity": {
        "noImplicitCoercions": "error"
      }
    }
  }
}
